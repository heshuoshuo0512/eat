# Smart Canteen production-style environment
NODE_ENV=production
HOST=0.0.0.0
PORT=8787

# REQUIRED in production. Use a long random value; it signs JWTs and encrypts AI keys.
SMART_CANTEEN_SECRET=replace-with-at-least-32-random-bytes

# Database
# Local fallback:
SMART_CANTEEN_DB=/app/data/smart-canteen.sqlite
# PostgreSQL production path:
DB_DRIVER=postgres
DB_MIGRATE=1
DATABASE_URL=postgres://smart_canteen:change-me@postgres:5432/smart_canteen

# Cache
REDIS_URL=redis://redis:6379

# Local uploads fallback
UPLOAD_DIR=/app/uploads
PUBLIC_UPLOAD_BASE_URL=/uploads

# S3 / MinIO object storage. Set S3_BUCKET to enable the S3 adapter.
S3_BUCKET=smart-canteen-uploads
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=smart-canteen
S3_SECRET_ACCESS_KEY=change-me-minio-secret
S3_PUBLIC_URL=http://localhost:9000/smart-canteen-uploads

# Optional OpenAI-compatible AI defaults. Admin UI settings override these per tenant.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_CHAT_MODEL=gpt-4o-mini
AI_VISION_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=12000

# WeChat Mini Program login. Required only when enabling POST /api/auth/wechat-login.
WECHAT_MINIAPP_APPID=
WECHAT_MINIAPP_SECRET=
WECHAT_LOGIN_TIMEOUT_MS=8000
